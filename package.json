{
  "name": "skill-vault",
  "version": "0.1.0",
  "description": "Local web app to discover and display AI coding tool skills",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "skill-vault": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "build": "bun build --compile --minify src/cli.ts --outfile skill-vault",
    "typecheck": "tsc --noEmit"
  },
  "private": false,
  "license": "MIT",
  "keywords": ["ai", "skills", "prompts", "rules", "claude", "cursor", "copilot", "gemini"],
  "repository": {
    "type": "git",
    "url": "https://github.com/leolobmaier/SkillOverview.git"
  },
  "files": [
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
